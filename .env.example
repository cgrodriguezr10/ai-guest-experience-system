# ============================================
# DATABASE CONFIGURATION
# ============================================
# Opción 1: PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/guest_experience_db

# Opción 2: SQLite (Más simple para desarrollo)
# DATABASE_URL=sqlite:./database.sqlite

DATABASE_TYPE=sqlite

# ============================================
# TWILIO WHATSAPP CONFIGURATION
# ============================================
TWILIO_ACCOUNT_SID=AC4e5e5b5e5b5e5b5e5b5e5b5e5b5e5b5
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155552671
TWILIO_WEBHOOK_URL=https://your-domain.com/webhook

# ============================================
# OPENAI CONFIGURATION
# ============================================
OPENAI_API_KEY=sk-proj-your_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ============================================
# HOTEL CONFIGURATION (Initial)
# ============================================
DEFAULT_HOTEL_ID=1
DEFAULT_HOTEL_NAME=The Plaza Hotel
DEFAULT_HOTEL_LANGUAGE=ES
DEFAULT_HOTEL_TIMEZONE=America/Bogota

# ============================================
# APP CONFIGURATION
# ============================================
APP_NAME=AI Guest Experience System
APP_VERSION=1.0.0
